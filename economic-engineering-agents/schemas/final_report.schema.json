{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Economic Engineering Final Report",
  "description": "Structured output of the Economic Engineering Conductor. This is the machine-readable version of the final markdown report.",
  "type": "object",
  "required": [
    "business_name",
    "report_date",
    "executive_summary",
    "primary_constraint",
    "top_profit_opportunities",
    "recommended_first_action",
    "next_experiment"
  ],
  "properties": {
    "business_name": { "type": "string" },
    "report_date": { "type": "string", "format": "date" },
    "analyst": { "type": "string", "description": "Which agents or system produced this report" },
    "executive_summary": {
      "type": "string",
      "description": "3-5 sentence summary: current state, primary constraint, top opportunity, first action"
    },
    "current_state": {
      "type": "object",
      "properties": {
        "revenue_estimate": { "type": ["string", "null"] },
        "margin_estimate": { "type": ["string", "null"] },
        "throughput_current": { "type": ["string", "null"] },
        "quality_score": { "type": ["number", "null"] },
        "primary_strengths": { "type": "array", "items": { "type": "string" } },
        "primary_weaknesses": { "type": "array", "items": { "type": "string" } }
      }
    },
    "primary_constraint": {
      "type": "object",
      "required": ["constraint", "constraint_type", "evidence", "estimated_profit_impact"],
      "properties": {
        "constraint": { "type": "string" },
        "constraint_type": {
          "type": "string",
          "enum": ["demand", "operations", "financial", "quality", "capacity", "trust"]
        },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "estimated_profit_impact": { "type": "string" },
        "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "top_profit_opportunities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["rank", "opportunity", "opportunity_score", "agent_source"],
        "properties": {
          "rank": { "type": "integer" },
          "opportunity": { "type": "string" },
          "opportunity_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "expected_margin_impact": { "type": ["string", "null"] },
          "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "agent_source": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "experiment_required": { "type": "boolean" }
        }
      }
    },
    "waste_identified": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "waste_type": { "type": "string" },
          "description": { "type": "string" },
          "estimated_annual_cost": { "type": ["string", "null"] }
        }
      }
    },
    "quality_risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": { "type": "string" },
          "financial_impact": { "type": ["string", "null"] },
          "prevention_action": { "type": ["string", "null"] }
        }
      }
    },
    "recommended_first_action": {
      "type": "string",
      "description": "The single most important action to take in the next 30 days"
    },
    "expected_margin_impact": {
      "type": "string",
      "description": "Expected margin improvement from implementing the top recommendations"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall confidence in the analysis given available data quality"
    },
    "missing_data": {
      "type": "array",
      "description": "Data that would materially change this analysis if available",
      "items": {
        "type": "object",
        "properties": {
          "data_needed": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "how_to_get_it": { "type": "string" }
        }
      }
    },
    "next_experiment": {
      "type": "object",
      "description": "The highest-priority experiment to run",
      "properties": {
        "name": { "type": "string" },
        "hypothesis": { "type": "string" },
        "duration": { "type": "string" },
        "success_metric": { "type": "string" }
      }
    },
    "roadmap_30_day": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "week": { "type": "string" },
          "action": { "type": "string" },
          "owner": { "type": ["string", "null"] },
          "expected_output": { "type": "string" }
        }
      }
    },
    "roadmap_90_day": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "month": { "type": "string" },
          "action": { "type": "string" },
          "depends_on": { "type": ["string", "null"] },
          "expected_output": { "type": "string" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "description": "All assumptions underlying this report, in order of most impactful",
      "items": { "type": "string" }
    }
  }
}
