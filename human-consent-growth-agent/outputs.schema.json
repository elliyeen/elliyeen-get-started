{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Human Consent Growth Agent — Outputs",
  "description": "Structured outputs produced after running the full agent pipeline.",
  "type": "object",
  "properties": {
    "desire_map": {
      "type": "object",
      "description": "Mapping of the audience's active desires to how the offer serves them.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "desire": { "type": "string" },
          "evidence": { "type": "string" },
          "how_offer_serves_it": { "type": "string" },
          "strength": { "type": "string", "enum": ["strong", "moderate", "weak"] }
        }
      }
    },
    "belief_map": {
      "type": "object",
      "description": "Existing beliefs in the market — supporting and blocking.",
      "properties": {
        "supporting_beliefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "belief": { "type": "string" },
              "how_to_reinforce": { "type": "string" }
            }
          }
        },
        "blocking_beliefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "belief": { "type": "string" },
              "how_to_dissolve": { "type": "string" }
            }
          }
        }
      }
    },
    "social_influence_map": {
      "type": "object",
      "description": "Who influences the audience and through what channels.",
      "properties": {
        "primary_influencers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "communities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "trusted_media": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "trust_drivers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "driver": { "type": "string" },
          "current_status": { "type": "string", "enum": ["present", "absent", "weak"] },
          "recommended_action": { "type": "string" }
        }
      },
      "description": "Factors that build trust with this audience and their current state."
    },
    "friction_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "friction": { "type": "string" },
          "location_in_journey": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "recommended_fix": { "type": "string" }
        }
      },
      "description": "Identified friction points preventing voluntary participation."
    },
    "community_opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "community": { "type": "string" },
          "entry_strategy": { "type": "string" },
          "value_to_offer": { "type": "string" }
        }
      }
    },
    "authority_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "asset": { "type": "string" },
          "type": { "type": "string", "enum": ["credential", "testimonial", "case_study", "publication", "partnership", "award"] },
          "verified": { "type": "boolean" },
          "deployment_channel": { "type": "string" }
        }
      }
    },
    "distribution_channels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": { "type": "string" },
          "audience_fit": { "type": "string", "enum": ["high", "medium", "low"] },
          "cost_tier": { "type": "string", "enum": ["free", "low", "medium", "high"] },
          "priority": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "growth_levers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "lever": { "type": "string" },
          "mechanism": { "type": "string" },
          "estimated_impact": { "type": "string", "enum": ["high", "medium", "low"] },
          "effort": { "type": "string", "enum": ["high", "medium", "low"] },
          "priority": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "ethical_risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "flag": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "moderate", "minor"] },
          "recommendation": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "recommendation": { "type": "string" },
          "rationale": { "type": "string" },
          "consent_check": {
            "type": "object",
            "properties": {
              "understanding": { "type": "boolean" },
              "transparency": { "type": "boolean" },
              "freedom": { "type": "boolean" },
              "alignment": { "type": "boolean" },
              "long_term_trust": { "type": "boolean" }
            }
          },
          "approved": { "type": "boolean" }
        }
      }
    }
  }
}
